# flux configuration
# Copy to ~/.config/flux/flux.env and fill in your values.
# Sensitive credentials (access key, secret key) are stored in macOS Keychain
# and are not part of this file — set them via 'flux config edit'.

# ── cloudflare R2 ─────────────────────────────────────────────────────────────
# FLUX_R2_BUCKET="my-r2-bucket"
# FLUX_R2_ACCOUNT_ID="your-cloudflare-account-id"

# ── routing ───────────────────────────────────────────────────────────────────
# FLUX_SIZE_THRESHOLD_MB=5    # files larger than this go to R2; smaller stay in Git
# FLUX_VERBOSE=false          # verbose hook output (true/false)
