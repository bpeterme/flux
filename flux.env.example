# flux configuration
# This file is managed by 'flux config' — you normally don't edit it by hand.
# Sensitive credentials (access key, secret key) are stored in macOS Keychain,
# keyed per bucket as flux.dvc.{bucket}.{access-key-id|secret-key}.

# ── DVC remotes ───────────────────────────────────────────────────────────────
# One or more Cloudflare R2 accounts. Format: "bucket:account_id"
# Credentials are stored in Keychain — not here.
FLUX_DVC_REMOTES=(
  # "my-r2-bucket:your-cloudflare-account-id"
  # "work-bucket:work-cloudflare-account-id"
)

# ── routing ───────────────────────────────────────────────────────────────────
FLUX_SIZE_CAP_MB=5        # files larger than this go to R2; smaller stay in Git
FLUX_VERBOSE=false        # verbose hook output (true/false)

# ── git accounts ──────────────────────────────────────────────────────────────
# One or more hosting accounts used to propose git remote URLs during 'flux add'.
# Format: "protocol:host:account"  (protocol: ssh or https)
FLUX_GIT_ACCOUNTS=(
  # "ssh:github.com:yourname"
  # "https:gitlab.com:workaccount"
)

# ─── companion tools ──────────────────────────────────────────────────────────

# claudebox — Claude Code container runtime
# Install: brew tap bpeterme/claudebox && brew install bpeterme/claudebox/claudebox
# Set up:  cbox build

# claudedot — cross-machine config + history sync via git
# Install: brew tap bpeterme/claudedot && brew install bpeterme/claudedot/claudedot
# Set up:  cdot config
