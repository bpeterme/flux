# flux configuration
# Copy this file to ~/.config/flux/flux.env and fill in your values.
# Run flux-setup once inside each Git repo you want to manage.

# Cloudflare R2 credentials (required)
FLUX_R2_BUCKET=my-r2-bucket
FLUX_R2_ACCOUNT_ID=your-cloudflare-account-id
FLUX_R2_ACCESS_KEY_ID=your-r2-access-key-id
FLUX_R2_SECRET_KEY=your-r2-secret-access-key

# R2 folder name used for this repo (optional).
# Defaults to the repo name derived from the Git remote URL.
# FLUX_R2_FOLDER=my-project

# File size threshold in MB (optional, default: 5).
# Files larger than this are routed to DVC/R2; smaller files stay in Git.
# FLUX_SIZE_THRESHOLD_MB=5

# Verbose hook output (optional, default: false).
# FLUX_VERBOSE=false
