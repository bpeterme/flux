#!/usr/bin/env bash
# =============================================================================
# pre-commit hook: auto-route files to DVC (R2) or Git (GitLab/GitHub/etc.)
#
# Routing rules (in order):
#   1. Binary file (any size)  → DVC → Cloudflare R2
#   2. Text file > SIZE_CAP → DVC → Cloudflare R2
#   3. Text file ≤ SIZE_CAP → Git → any Git remote
#
# Edge cases handled automatically:
#   - File grows past cap: migrated cleanly from Git history to DVC
#   - File shrinks below cap: detected from .dvc list, migrated back to Git
#   - File deleted: orphaned .dvc pointer staged for removal
#   - File renamed: old .dvc pointer cleaned up; new name routed fresh
#
# .dvcignore is kept in sync with every .gitignore in the repo automatically.
# Mental model: anything in .gitignore is invisible to both Git and DVC.
#
# Configuration (set via git config, applies per repo):
#   git config dvc-router.size-cap-mb 5     # default: 5 MB
#   git config dvc-router.verbose true           # default: false
#
# DVC is located automatically — works with system Homebrew (/opt/homebrew),
# Intel Homebrew (/usr/local), and user-local Homebrew (~/.homebrew etc.)
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Locate DVC — checks all common Homebrew install locations before PATH
# ---------------------------------------------------------------------------
find_dvc() {
  local candidates=(
    "/opt/homebrew/bin/dvc"      # system Homebrew, Apple Silicon
    "/usr/local/bin/dvc"         # system Homebrew, Intel
    "${HOME}/.homebrew/bin/dvc"  # user-local Homebrew (common)
    "${HOME}/homebrew/bin/dvc"   # user-local Homebrew (alternative)
  )

  for candidate in "${candidates[@]}"; do
    if [[ -x "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
  done

  # Last resort: whatever is in PATH (e.g. pip-installed, conda, etc.)
  if command -v dvc &>/dev/null; then
    command -v dvc
    return 0
  fi

  return 1
}

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------
SIZE_CAP_MB=$(git config --get dvc-router.size-cap-mb 2>/dev/null || echo "5")
SIZE_CAP_BYTES=$(( SIZE_CAP_MB * 1024 * 1024 ))
VERBOSE=$(git config --get dvc-router.verbose 2>/dev/null || echo "false")

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
log() {
  if [[ "$VERBOSE" == "true" ]]; then
    echo "[dvc-router] $*"
  fi
}

info() {
  echo "[dvc-router] $*"
}

warn() {
  echo "[dvc-router] WARNING: $*" >&2
}

# ---------------------------------------------------------------------------
# Sync every .dvcignore from its sibling .gitignore
#
# Strips comments and blank lines from each .gitignore found in the repo
# and writes the result to a sibling .dvcignore, then stages it.
# Runs after file routing so DVC-added .gitignore entries are also captured.
#
# Mental model: anything in .gitignore is invisible to both Git and DVC.
# ---------------------------------------------------------------------------
sync_dvcignore() {
  # Only process tracked/staged .gitignore files — git ls-files skips gitignored
  # sub-repos and excluded directories, which find would otherwise traverse.
  while IFS= read -r gitignore_path; do
    local dir dvcignore_path
    dir=$(dirname "$gitignore_path")
    dvcignore_path="${dir}/.dvcignore"

    # Strip comment lines and blank lines; an empty result is still valid
    grep -v '^\s*#' "$gitignore_path" | grep -v '^\s*$' > "$dvcignore_path" || true

    git add "$dvcignore_path"
    log "Synced: $dvcignore_path ← $gitignore_path"
  done < <(git ls-files | grep '\.gitignore$')
}

# ---------------------------------------------------------------------------
# Clean up orphaned .dvc pointer files
#
# Handles two cases that Git can't see on its own (because the actual data
# files are .gitignore'd):
#
#   Delete: user removes a DVC-tracked file from disk. The .dvc pointer still
#     exists in Git — this stages it for removal.
#
#   Rename: user moves a DVC-tracked file. The old .dvc pointer is orphaned
#     (its target is gone) — this removes it. The new filename will be picked
#     up by the staging loop below and routed fresh.
#
# In both cases the DVC-added entry in the sibling .gitignore is also cleaned
# up so .gitignore doesn't accumulate stale entries.
# ---------------------------------------------------------------------------
cleanup_orphaned_dvc_pointers() {
  local cleaned=()

  # Iterate over every .dvc pointer file currently tracked by Git
  while IFS= read -r dvc_file; do
    [[ -z "$dvc_file" ]] && continue

    # Parse the target path from the .dvc YAML (path: field, first occurrence)
    local target_rel
    target_rel=$(grep '^\s*path:' "$dvc_file" 2>/dev/null \
      | head -1 \
      | sed 's/.*path:[[:space:]]*//' \
      | tr -d '"' \
      | tr -d "'")
    [[ -z "$target_rel" ]] && continue

    # Target path is relative to the directory containing the .dvc file
    local dvc_dir target_abs
    dvc_dir=$(dirname "$dvc_file")
    target_abs="${dvc_dir}/${target_rel}"

    # If the target still exists, the pointer is healthy — nothing to do
    [[ -e "$target_abs" ]] && continue

    log "Orphaned .dvc pointer: $dvc_file (target missing: $target_abs)"

    # Stage the .dvc pointer for deletion
    git rm --cached "$dvc_file" &>/dev/null || true

    # Remove the DVC-added /<basename> entry from the sibling .gitignore
    # (backward-compat) and the full-path entry from the root .gitignore
    # (current consolidated style). Delete the sibling if it becomes empty.
    local target_name; target_name=$(basename "$target_rel")
    local gitignore_path="${dvc_dir}/.gitignore"
    if [[ -f "$gitignore_path" ]]; then
      local _tmp; _tmp=$(mktemp)
      grep -vxF "/$target_name" "$gitignore_path" > "$_tmp" || true
      mv "$_tmp" "$gitignore_path"
      if [[ ! -s "$gitignore_path" ]]; then
        rm -f "$gitignore_path"
      else
        git add "$gitignore_path"
      fi
    fi
    if [[ "$dvc_dir" != "." ]]; then
      local root_path; root_path="${dvc_dir}/${target_rel}"
      if [[ -f ".gitignore" ]] && grep -qxF "$root_path" .gitignore 2>/dev/null; then
        local _tmp; _tmp=$(mktemp)
        grep -vxF "$root_path" .gitignore > "$_tmp" || true
        mv "$_tmp" .gitignore
        git add .gitignore
      fi
    fi

    cleaned+=("$dvc_file")
  done < <(git ls-files '*.dvc' 2>/dev/null)

  if (( ${#cleaned[@]} > 0 )); then
    info "Cleaned up orphaned DVC pointers (${#cleaned[@]}):"
    for f in "${cleaned[@]}"; do
      info "  ✦ $f (target deleted or renamed)"
    done
  fi
}

# ---------------------------------------------------------------------------
# Migrate DVC-tracked files back to Git if they now fall below the cap
#
# Scans every .dvc pointer file known to Git. For each, checks the current
# on-disk state of the target file:
#   - Still binary → stays in DVC
#   - Still above cap → stays in DVC
#   - Now text AND below cap → migrated to Git
#
# Uses dvc remove to cleanly delete the pointer and its .gitignore entry,
# then stages the file so it flows through the routing loop as a normal Git
# file. This is the authoritative approach: reading .dvc files directly means
# we catch every DVC-tracked file regardless of what is or isn't in .gitignore.
#
# Note: dvc gc --cloud --all-branches runs automatically after any migration
# to purge now-unreferenced R2 data while preserving data on other branches.
# ---------------------------------------------------------------------------
migrate_dvc_to_git() {
  local migrated=()

  while IFS= read -r dvc_file; do
    [[ -z "$dvc_file" ]] && continue

    # Parse the target path from the .dvc YAML (path: field, first occurrence)
    local target_rel
    target_rel=$(grep '^\s*path:' "$dvc_file" 2>/dev/null \
      | head -1 \
      | sed 's/.*path:[[:space:]]*//' \
      | tr -d '"' \
      | tr -d "'")
    [[ -z "$target_rel" ]] && continue

    local dvc_dir target_abs
    dvc_dir=$(dirname "$dvc_file")
    target_abs="${dvc_dir}/${target_rel}"

    # Skip missing targets — handled by cleanup_orphaned_dvc_pointers
    [[ ! -f "$target_abs" ]] && continue

    # Check binary status — binary files always stay in DVC regardless of size
    if ! grep -qI . "$target_abs" 2>/dev/null; then
      log "Still binary, keeping in DVC: $target_abs"
      continue
    fi

    # Check size — still above cap, stays in DVC
    local file_size
    file_size=$(wc -c < "$target_abs" | tr -d ' ')
    if (( file_size > SIZE_CAP_BYTES )); then
      log "Still above cap ($(( file_size / 1024 / 1024 )) MB), keeping in DVC: $target_abs"
      continue
    fi

    # File is now text AND below cap → migrate back to Git
    info "Migrating DVC → Git (now $(( file_size / 1024 )) KB, below ${SIZE_CAP_MB} MB cap): $target_abs"

    # dvc remove deletes the .dvc pointer and removes the entry from .gitignore
    # --keep-outs ensures the actual file is NOT deleted from disk
    "$DVC" remove "$dvc_file" --keep-outs --quiet 2>/dev/null || {
      warn "  dvc remove failed for $dvc_file — skipping migration"
      continue
    }

    # dvc remove cleaned the sibling .gitignore entry; also clean the root
    # .gitignore (consolidated format used for non-root files).
    if [[ "$dvc_dir" != "." ]]; then
      if [[ -f ".gitignore" ]] && grep -qxF "$target_abs" .gitignore 2>/dev/null; then
        local _tmp; _tmp=$(mktemp)
        grep -vxF "$target_abs" .gitignore > "$_tmp" || true
        mv "$_tmp" .gitignore
        git add .gitignore
      fi
    fi

    # Stage the file — it's no longer gitignored, so git add works now
    git add "$target_abs"

    migrated+=("$target_abs")
  done < <(git ls-files '*.dvc' 2>/dev/null)

  if (( ${#migrated[@]} > 0 )); then
    info "Migrated DVC → Git (${#migrated[@]} file(s)):"
    for f in "${migrated[@]}"; do
      info "  ✦ $f"
    done
    info ""
    info "  Cleaning up unreferenced R2 data..."
    "$DVC" gc --cloud --all-branches --force --quiet 2>/dev/null && \
      info "  R2 cleanup complete." || \
      warn "  R2 cleanup failed — run 'dvc gc --cloud --all-branches' manually."
  fi
}

# ---------------------------------------------------------------------------
# Resolve DVC binary
# ---------------------------------------------------------------------------
DVC=$(find_dvc) || {
  echo "[dvc-router] ERROR: dvc not found in any known location."
  echo ""
  echo "  System Homebrew (Apple Silicon / Intel):"
  echo "    brew install dvc && pip install dvc-s3"
  echo "    brew install dvc && uv tool install dvc-s3"
  echo ""
  echo "  User-local Homebrew:"
  echo "    <your-brew> install dvc && pip install dvc-s3"
  echo "    <your-brew> install dvc && uv tool install dvc-s3"
  echo ""
  echo "  Or set your Homebrew bin directory in PATH before committing."
  exit 1
}

log "Using DVC at: $DVC"

# ---------------------------------------------------------------------------
# Capture the user's originally staged files BEFORE cleanup or migration
# run — both may stage their own bookkeeping files (.gitignore edits, pointer
# deletions, migrated data files) which must not be re-processed by the
# routing loop below.
# ---------------------------------------------------------------------------
staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

# ---------------------------------------------------------------------------
# Cleanup orphaned .dvc pointers (deleted / renamed DVC-tracked files)
# Runs before staged file processing so stale .gitignore entries are cleared
# before .dvcignore is regenerated
# ---------------------------------------------------------------------------
cleanup_orphaned_dvc_pointers

# ---------------------------------------------------------------------------
# Migrate DVC-tracked files that now fall below the cap back to Git
# Runs after cleanup (so deleted targets are already gone) and before the
# routing loop (so the routing loop only sees the user's original staged set)
# ---------------------------------------------------------------------------
migrate_dvc_to_git

if [[ -z "$staged_files" ]]; then
  log "No staged files to process."
  # Still sync .dvcignore in case cleanup or migration modified any .gitignore files
  sync_dvcignore
  exit 0
fi

dvc_routed=()
git_kept=()
git_migrated=0

# ---------------------------------------------------------------------------
# Process each staged file
# ---------------------------------------------------------------------------
while IFS= read -r file; do
  # Skip files that don't exist on disk (e.g. submodules, symlinks to nowhere)
  if [[ ! -f "$file" ]]; then
    log "Skipping non-regular file: $file"
    continue
  fi

  # Skip files already tracked by DVC (have a corresponding .dvc file)
  if [[ -f "${file}.dvc" ]]; then
    log "Already DVC-tracked, skipping: $file"
    continue
  fi

  # ------------------------------------------------------------------
  # Binary detection: grep -qI reads the file and exits non-zero if
  # it contains binary (non-text) content — same heuristic Git uses.
  # ------------------------------------------------------------------
  is_binary=false
  if ! grep -qI . "$file" 2>/dev/null; then
    is_binary=true
  fi

  # Size in bytes
  file_size=$(wc -c < "$file" | tr -d ' ')

  # ------------------------------------------------------------------
  # Routing decision
  # ------------------------------------------------------------------
  if [[ "$is_binary" == "true" ]]; then
    log "Binary file detected → DVC: $file"
    route="dvc"
  elif (( file_size > SIZE_CAP_BYTES )); then
    log "Large text file ($(( file_size / 1024 / 1024 )) MB > ${SIZE_CAP_MB} MB cap) → DVC: $file"
    route="dvc"
  else
    log "Text file → Git: $file"
    route="git"
  fi

  # ------------------------------------------------------------------
  # Execute routing
  # ------------------------------------------------------------------
  if [[ "$route" == "dvc" ]]; then
    # Detect Git → DVC transition: file previously committed to Git history
    # but belongs in DVC (binary, or grew past the size cap).
    # git rm --cached removes it from the index cleanly in both cases
    # (whether it was tracked or merely staged), so no separate branch needed.
    if git ls-files --error-unmatch "$file" &>/dev/null 2>&1; then
      if [[ "$is_binary" == "true" ]]; then
        log "Moving to DVC (binary, was tracked by Git): $file"
      else
        log "Moving to DVC (crossed size cap, was tracked by Git): $file"
      fi
      git_migrated=$(( git_migrated + 1 ))
    fi

    # Unstage from Git (handles both newly staged and previously tracked files)
    git rm --cached "$file" &>/dev/null || true

    # Hand off to DVC — creates <file>.dvc and updates .gitignore
    "$DVC" add "$file" --quiet

    # Stage the DVC pointer.
    git add "${file}.dvc"

    # DVC wrote /<basename> into the sibling .gitignore. For non-root files,
    # move that entry to the root .gitignore as a full path so DVC tracking
    # never creates nested .gitignore files. For root-level files the sibling
    # IS the root, so just stage it as-is.
    _dvc_dir=$(dirname "$file")
    _dvc_name=$(basename "$file")
    if [[ "$_dvc_dir" != "." ]]; then
      _dvc_gi="${_dvc_dir}/.gitignore"
      if [[ -f "$_dvc_gi" ]] && grep -qxF "/$_dvc_name" "$_dvc_gi" 2>/dev/null; then
        _tmp=$(mktemp)
        grep -vxF "/$_dvc_name" "$_dvc_gi" > "$_tmp" || true
        mv "$_tmp" "$_dvc_gi"
        if [[ ! -s "$_dvc_gi" ]]; then
          rm -f "$_dvc_gi"
        else
          git add "$_dvc_gi"
        fi
      fi
      grep -qxF "$file" .gitignore 2>/dev/null || echo "$file" >> .gitignore
    fi
    git add .gitignore

    dvc_routed+=("$file")
  else
    git_kept+=("$file")
  fi

done <<< "$staged_files"

# ---------------------------------------------------------------------------
# Sync .dvcignore files from .gitignore files
# Runs after routing so DVC-added .gitignore entries are included
# ---------------------------------------------------------------------------
sync_dvcignore

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
if (( ${#dvc_routed[@]} > 0 )); then
  log "Routed to DVC / Cloudflare R2 (${#dvc_routed[@]} file(s)):"
  for f in "${dvc_routed[@]}"; do
    log "  ✦ $f"
  done
fi

if (( ${#git_kept[@]} > 0 )); then
  log "Kept in Git (${#git_kept[@]} file(s)):"
  for f in "${git_kept[@]}"; do
    log "  · $f"
  done
fi

# Compact always-visible summary
_dvc_n=${#dvc_routed[@]}
_git_n=${#git_kept[@]}
if (( _dvc_n > 0 || _git_n > 0 )); then
  _summary="[dvc-router] Routed: ${_dvc_n} → R2  |  ${_git_n} → Git"
  if (( git_migrated > 0 )); then
    _summary+="  (${git_migrated} moved out of Git history — run 'dvc push' then optionally 'git filter-repo' to scrub)"
  fi
  echo "$_summary"
fi
if (( _dvc_n > 0 )); then
  info "Remember: dvc push"
fi

exit 0
